// Slices are references to their backing array: assignment and ranges alias
// the same data, they don't copy it.
func main(): int {
  var s = new([]int, 3);
  s[0] = 1;
  s[1] = 2;
  s[2] = 3;

  // Assigning a slice to another variable aliases the same elements.
  var t = s;
  t[0] = 100;
  printf("%d %d\n", s[0], t[0]);

  // A range aliases the original elements: writes go both ways.
  var r = s[1:3];
  r[0] = 200;
  printf("%d %d\n", s[1], r[0]);
  s[2] = 300;
  printf("%d %d\n", s[2], r[1]);

  // A range of a range still aliases the original.
  var rr = s[0:3][1:2];
  rr[0] = 400;
  printf("%d\n", s[1]);

  dispose(s);
  return 0;
}
